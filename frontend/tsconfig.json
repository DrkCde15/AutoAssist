{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./public/*"]
    },
    "skipLibCheck": true
  },
  "include": ["public/static/js/**/*.js"],
  "exclude": ["node_modules", "**/*.spec.js", "**/*.test.js"]
}
