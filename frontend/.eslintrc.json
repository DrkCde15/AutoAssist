{
  "env": {
    "browser": true,
    "es2023": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "prefer-const": "warn",
    "no-empty": ["error", { "allowEmptyCatch": true }]
  },
  "globals": {
    "Auth": "readonly",
    "CONFIG": "readonly",
    "DOMPurify": "readonly",
    "marked": "readonly",
    "SecurityUtils": "readonly",
    "module": "readonly",
    "require": "readonly",
    "clients": "readonly",
    "caches": "readonly",
    "registration": "readonly",
    "skipWaiting": "readonly"
  }
}
