{
  "env": {
    "browser": true,
    "es2023": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "prefer-const": "warn"
  },
  "globals": {
    "Auth": "readonly",
    "CONFIG": "readonly",
    "DOMPurify": "readonly",
    "marked": "readonly"
  }
}
